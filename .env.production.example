# ============================================================
# MTI Business Control Platform - Ejemplo para produccion
# ============================================================
# No uses estos valores directamente. Configuralos como secretos
# en la plataforma de despliegue o en un gestor de secretos.

NODE_ENV="production"
NEXTAUTH_URL="https://tu-dominio.com"

AUTH_SECRET="genera-un-secreto-largo-y-aleatorio"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="usa-una-password-fuerte"

POSTGRES_DB="mti_business_control"
POSTGRES_USER="mti_app"
POSTGRES_PASSWORD="usa-una-password-fuerte-para-postgres"

DATABASE_URL="postgresql://mti_app:usa-una-password-fuerte-para-postgres@db:5432/mti_business_control?schema=public"
DIRECT_URL="postgresql://mti_app:usa-una-password-fuerte-para-postgres@db:5432/mti_business_control?schema=public"

# En produccion es preferible usar migraciones versionadas.
PRISMA_SCHEMA_SYNC="migrate"

FACTORIAL_API_KEY=""
FACTORIAL_COMPANY_ID=""
