# ============================================================
# MTI Business Control Platform - Variables de entorno
# ============================================================
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas .env a Git.

# ── PostgreSQL local / Docker ─────────────────────────────
POSTGRES_DB="mti_business_control"
POSTGRES_USER="mti_app"
POSTGRES_PASSWORD="cambia-esta-password-de-postgres"

# Si ejecutas Next fuera de Docker contra la BD local publicada por Compose:
DATABASE_URL="postgresql://mti_app:cambia-esta-password-de-postgres@localhost:5432/mti_business_control?schema=public"
DIRECT_URL="postgresql://mti_app:cambia-esta-password-de-postgres@localhost:5432/mti_business_control?schema=public"

# Usa migraciones versionadas. Para prototipos locales se puede cambiar a "push".
PRISMA_SCHEMA_SYNC="migrate"

# ── Factorial API (futuro) ────────────────────────────────
FACTORIAL_API_KEY=""
FACTORIAL_COMPANY_ID=""

# ── Next.js ───────────────────────────────────────────────
AUTH_SECRET="cambia-esto-por-un-string-aleatorio-seguro"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambia-esta-password"
NEXTAUTH_URL="http://localhost:3000"
