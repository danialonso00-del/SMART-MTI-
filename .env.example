# ============================================================
# MTI Business Control Platform - Variables de entorno
# ============================================================
# Copia este fichero como .env y rellena los valores reales.
# NUNCA subas .env a Git.

# ── Supabase / PostgreSQL ─────────────────────────────────
# Obtén estas URLs en: Supabase → Settings → Database → Connection string

# Connection pooling (usa esta para Prisma en producción/serverless)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (usa esta para migraciones y seed)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ── Factorial API (futuro) ────────────────────────────────
FACTORIAL_API_KEY=""
FACTORIAL_COMPANY_ID=""

# ── Next.js ───────────────────────────────────────────────
AUTH_SECRET="cambia-esto-por-un-string-aleatorio-seguro"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambia-esta-password"
NEXTAUTH_URL="http://localhost:3000"
